# DecentralChain Mass Transfer — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Sender wallet private key (base58)
DCC_PRIVATE_KEY=your_private_key_here

# Asset ID to transfer
DCC_ASSET_ID=your_asset_id_here

# Node URL
DCC_NODE=https://mainnet-node.decentralchain.io

# Chain ID (DecentralChain mainnet = '?' / ASCII 63)
DCC_CHAIN_ID=?

# Transfer settings
NUM_WALLETS=2000
SENDS_PER_WALLET=10
MAX_WORKERS=200
BATCH_SIZE=100

# Hyper/Blazing engine settings
REAL_WORKERS=200
SIM_WORKERS=80
TARGET_RATE=25000
DURATION=60

# Rate limiting (0 = no delay)
RATE_LIMIT_DELAY=0
