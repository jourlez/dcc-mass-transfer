# DecentralChain Mass Transfer — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Sender wallet private key (base58)
DCC_PRIVATE_KEY=your_private_key_here

# Asset ID to transfer (leave blank to use native DCC)
DCC_ASSET_ID=

# Node URL
# Mainnet:  https://mainnet-node.decentralchain.io
# Testnet:  http://66.228.55.154:6868
DCC_NODE=https://mainnet-node.decentralchain.io

# Chain ID character
# Mainnet:  ?  (ASCII 63)
# Testnet:  !  (ASCII 33)
DCC_CHAIN_ID=?

# Transfer settings
NUM_WALLETS=2000
SENDS_PER_WALLET=10
MAX_WORKERS=200
BATCH_SIZE=100

# Hyper/Blazing engine settings
REAL_WORKERS=200
SIM_WORKERS=80
TARGET_RATE=25000
DURATION=60

# Rate limiting (0 = no delay)
RATE_LIMIT_DELAY=0
